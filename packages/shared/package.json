{
  "x-comment": [
    "1. 共享基础包的 package 配置。",
    "2. 作用：声明纯类型与元数据层的导出方式，并提供构建、类型检查脚本。",
    "3. 维护要点：对外导出入口或构建目标调整时，需要先更新这里。"
  ],
  "name": "@statekit-vue/shared",
  "version": "0.3.0",
  "description": "Shared types and metadata for StateKit state recipes.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": false,
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "keywords": [
    "saas",
    "ui",
    "metadata",
    "design-system",
    "state-machine",
    "vue"
  ],
  "homepage": "https://github.com/gaoliuqing9178/StateKit#readme",
  "bugs": {
    "url": "https://github.com/gaoliuqing9178/StateKit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gaoliuqing9178/StateKit.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "prebuild": "node ../../scripts/clean-dist.mjs ./dist",
    "build": "tsc -p tsconfig.build.json",
    "typecheck": "tsc -p tsconfig.build.json --noEmit"
  }
}
