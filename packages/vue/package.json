{
  "x-comment": [
    "1. Vue 组件包的 package 配置。",
    "2. 作用：定义 Vue 包的导出入口、样式入口和构建脚本。",
    "3. 维护要点：发布入口或 peer 版本变化时，需要优先检查这里。"
  ],
  "name": "@statekit-vue/vue",
  "version": "0.3.0",
  "description": "Category-first Vue state UI for SaaS products.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "README.md"
  ],
  "sideEffects": [
    "./dist/style.css"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./styles.css": "./dist/style.css"
  },
  "keywords": [
    "vue",
    "saas",
    "ui",
    "states",
    "empty-state",
    "error-state",
    "loading-state"
  ],
  "homepage": "https://github.com/gaoliuqing9178/StateKit#readme",
  "bugs": {
    "url": "https://github.com/gaoliuqing9178/StateKit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gaoliuqing9178/StateKit.git"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "vue": "^3.4.0"
  },
  "dependencies": {
    "@statekit-vue/shared": "0.3.0"
  },
  "scripts": {
    "prebuild": "node ../../scripts/clean-dist.mjs ./dist",
    "build": "vite build && vue-tsc -p tsconfig.build.json",
    "typecheck": "vue-tsc --noEmit -p tsconfig.json"
  }
}
